# Example Kubernetes Secret manifest for Infoblox credentials.
#
# Copy this file to credentials.yaml and replace the placeholder values
# with your actual Infoblox username and password.
#
apiVersion: v1
kind: Secret
metadata:
  name: infoblox-credentials
type: Opaque
stringData:
  username: your-infoblox-username
  password: your-infoblox-password
